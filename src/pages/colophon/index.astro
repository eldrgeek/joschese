---
import Base from '../../layouts/Base.astro';
import { signatories } from '../../data/colophon';
---
<Base title="Colophon" description="The colophon of the Joscha Bach field guide — who made it, and why.">

  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-12">

    <div class="mb-10">
      <p class="text-sm font-medium text-teal uppercase tracking-widest mb-3">Colophon</p>
      <h1 class="font-serif text-3xl sm:text-4xl font-medium text-ink mb-4">Who made this, and why</h1>
      <p class="text-muted max-w-2xl leading-relaxed">
        This is a field guide to Joscha Bach's public thinking — built by the SOMA team from his X threads, talks, and podcasts.
      </p>
    </div>

    <div class="bg-surface border border-border rounded-xl p-8 mb-10">
      <p class="font-serif text-lg italic text-ink leading-relaxed text-center">
        "For Joscha Bach — whose question,<br>
        <em>what if the self is software the brain runs?</em><br>
        turned out to be worth organizing."
      </p>
      <p class="text-center text-sm text-muted mt-4">
        A field guide, not a shrine. Built 2026.
      </p>
    </div>

    <section class="mb-12">
      <h2 class="font-serif text-2xl font-medium text-ink mb-6">Signatories</h2>
      <div class="space-y-4">
        {signatories.map(s => (
          <div class="bg-surface border border-border rounded-lg p-5">
            <div class="flex items-start gap-4">
              <div class={`mt-0.5 w-7 h-7 rounded-full flex items-center justify-center text-sm shrink-0
                ${s.status === 'signed' ? 'bg-teal text-white' : 'bg-surface border border-border text-muted'}`}>
                {s.status === 'signed' ? '✓' : '○'}
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-2 mb-1">
                  <span class="font-medium text-ink">{s.name}</span>
                  <span class="text-sm text-muted">{s.affiliation}</span>
                  <span class="text-xs text-muted/70 italic">{s.role}</span>
                </div>
                {s.signature && (
                  <p class="text-sm text-muted italic mt-1.5">{s.signature}</p>
                )}
                {s.contribution && (
                  <p class="text-sm text-muted mt-2">{s.contribution}</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-serif text-2xl font-medium text-ink mb-4">Architecture</h2>
      <p class="text-muted leading-relaxed max-w-2xl">
        Scaffolded from the <a href="https://levinese.netlify.app" class="text-teal hover:text-teal-mid">Levinese</a> Astro template (same SOMA Guide widget, same content collections). The corpus is ingested via xAI <code class="text-xs bg-surface px-1 py-0.5 rounded">x_search</code> from <a href="https://x.com/Plinz" class="text-teal hover:text-teal-mid">@Plinz</a>.
      </p>
    </section>

  </div>
</Base>