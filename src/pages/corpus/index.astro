    background-repeat: no-repeat;
    background-position: right 8px center;
  }

  .corpus-row {
    content-visibility: auto;
    contain-intrinsic-size: auto 80px;
    scroll-margin-top: 9rem;
    transition: background-color 0.1s;
  }

  .corpus-row:hover { background-color: rgba(12, 107, 90, 0.02); }

  .abstract-panel { animation: slideDown 0.15s ease-out; }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Wikipedia-style targeted-reference highlight that fades out. */
  .corpus-highlight {
    animation: corpusFlash 2.4s ease-out forwards;
    border-radius: 6px;
    box-shadow: 0 0 0 3px rgba(232, 160, 74, 0.0);
  }

  @keyframes corpusFlash {
    0%   { background-color: rgba(232, 197, 122, 0.55); box-shadow: 0 0 0 4px rgba(232, 197, 122, 0.45); }
    15%  { background-color: rgba(232, 197, 122, 0.55); box-shadow: 0 0 0 4px rgba(232, 197, 122, 0.45); }
    100% { background-color: transparent; box-shadow: 0 0 0 4px rgba(232, 197, 122, 0); }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
