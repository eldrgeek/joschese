---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Joschese — a field guide to Joscha Bach's ideas. Dictionary, corpus browser, and conversation with the computational philosophy of consciousness." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Joschese</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --font-serif: 'Lora', Georgia, serif;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    body { font-family: var(--font-sans); }
    h1, h2, h3, h4, .serif { font-family: var(--font-serif); }
  </style>
</head>
<body class="bg-parchment text-ink min-h-screen flex flex-col">
  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-parchment/95 backdrop-blur-sm border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-serif font-medium text-lg text-teal hover:text-teal-mid transition-colors tracking-wide">
        Joschese
      </a>
      <div class="flex items-center gap-6 text-sm font-medium text-muted">
        <a href="/dictionary/" class="hover:text-ink transition-colors">Dictionary</a>
        <a href="/corpus/" class="hover:text-ink transition-colors">Corpus</a>
        <a href="/atlas/" class="hover:text-ink transition-colors">Atlas</a>
        <a href="/ask/" class="hover:text-ink transition-colors">Ask</a>
        <a href="/colophon/" class="hover:text-ink transition-colors">Colophon</a>
        <button id="soma-signin" type="button" class="hover:text-ink transition-colors">Sign in</button>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-muted text-sm text-center sm:text-left">
        A field guide to Joscha Bach's ideas. Built by the SOMA team. 2026.
      </p>
      <p class="text-muted text-xs opacity-60 font-mono">
        SOMA · built by Dee
      </p>
    </div>
  </footer>
  <!--
    Netlify Identity widget (only used for the Decap CMS admin login flow).
    These MUST be `is:inline` so Astro does NOT fold them into each page's
    bundled ES module graph. The widget is served cross-origin with no
    Access-Control-Allow-Origin header; when imported as a module dependency
    the browser blocks it on CORS, which aborts the entire page module and
    silently kills corpus search, dictionary filter, and sort site-wide.
  -->
  <!--
    SOMA visitor auth (Supabase magic-link). This is the IDENTITY layer the
    SOMA guide reads (window.SomaAuth.session) so a signed-in visitor gets a
    persistent, recognized relationship with the Joscha guide across visits and
    devices. It is SEPARATE from the Netlify Identity widget below, which is
    only the Decap CMS admin login. Must be `is:inline` (see CORS note below).
  -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
  <script is:inline src="/js/soma-auth-config.js"></script>
  <script is:inline src="/js/soma-auth.js"></script>
  <script is:inline>
    (function () {
      if (!window.SomaAuth) return;
      // Bridge the Supabase session onto the property the SOMA guide reads.
      window.SomaAuth.onAuthStateChange(function (event, session) {
        window.SomaAuth.session = session || null;
        var btn = document.getElementById('soma-signin');
        if (btn) btn.textContent = session && session.user ? 'Sign out' : 'Sign in';
        // Best-effort: let the guide re-read identity if it exposes a hook.
        if (window.somaGuide && typeof window.somaGuide.refreshIdentity === 'function') {
          try { window.somaGuide.refreshIdentity(); } catch (e) {}
        }
      });
      window.SomaAuth.init(window.SOMA_AUTH_CONFIG.url, window.SOMA_AUTH_CONFIG.anonKey);
      // Minimal sign-in/out affordance (v0 — refine UX later).
      document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('soma-signin');
        if (!btn) return;
        btn.addEventListener('click', function () {
          if (window.SomaAuth.session && window.SomaAuth.session.user) {
            window.SomaAuth.signOut();
            return;
          }
          var email = window.prompt('Enter your email to sign in. You will get a magic link to click — then the guide remembers you across visits.');
          if (!email) return;
          window.SomaAuth.signInWithOtp(email, { emailRedirectTo: window.location.origin + '/' })
            .then(function (r) {
              window.alert(r && r.error ? ('Sign-in error: ' + r.error.message) : 'Check your email for the magic link.');
            });
        });
      });
    })();
  </script>

  <link rel="stylesheet" href="https://soma-guide.netlify.app/soma-guide.css" />
  <script is:inline src="/joscha-guide-config.js"></script>
  <script is:inline src="https://soma-guide.netlify.app/soma-guide.js"></script>
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', user => {
        if (!user) {
          window.netlifyIdentity.on('login', () => {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>
</body>
</html>